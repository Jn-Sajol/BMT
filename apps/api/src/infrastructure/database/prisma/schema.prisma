  @@map("automation_templates")
}

model AutomationTemplateVersion {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId     String   @map("template_id") @db.Uuid
  version        String
  canvasJson     Json     @map("canvas_json")
  definitionJson Json     @map("definition_json")
  checksum       String
  signature      String
  changelog      String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  template       AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@map("automation_template_versions")
}

model AutomationTemplateInstallation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId       String   @map("template_id") @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  installedVersion String   @map("installed_version")
  installedAt      DateTime @default(now()) @map("installed_at") @db.Timestamptz
  status           String

  template         AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("automation_template_installations")
}

model AutomationTemplateAnalytics {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String   @map("template_id") @db.Uuid
  installs    Int      @default(0)
  clones      Int      @default(0)
  executions  Int      @default(0)
  successRate Float    @default(1.0) @map("success_rate")
  averageRoi  Float    @default(0.0) @map("average_roi")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  template    AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("automation_template_analytics")
}

model AutomationTemplateReview {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   String   @map("template_id") @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  rating       Int
  comment      String?
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  template     AutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("automation_template_reviews")
}

model AutomationTemplateCategory {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  @@map("automation_template_categories")
}

model AutomationTemplateTag {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique

  @@map("automation_template_tags")
}
