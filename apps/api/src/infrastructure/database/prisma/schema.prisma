model AutomationSchedule {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  provider       String
  ruleId         String    @map("rule_id") @db.Uuid
  cronExpression String?   @map("cron_expression")
  timezone       String
  scheduleType   String    @map("schedule_type") // CRON, INTERVAL, ONE_TIME, etc.
  status         String    // ACTIVE, PAUSED
  nextRunAtUtc   DateTime? @map("next_run_at_utc") @db.Timestamptz
  lastRunAtUtc   DateTime? @map("last_run_at_utc") @db.Timestamptz
  startDate      DateTime? @map("start_date") @db.Timestamptz
  endDate        DateTime? @map("end_date") @db.Timestamptz
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  executions     AutomationScheduleExecution[]
  lock           AutomationScheduleLock?

  @@map("automation_schedules")
}

model AutomationScheduleExecution {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  scheduleId     String    @map("schedule_id") @db.Uuid
  correlationId  String    @map("correlation_id") @db.Uuid
  nodeId         String    @map("node_id")
  status         String    // RUNNING, SUCCESS, FAILED
  startedAt      DateTime  @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  durationMs     Int       @default(0) @map("duration_ms")
  retryCount     Int       @default(0) @map("retry_count")
  error          String?
  metadata       Json?

  schedule       AutomationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("automation_schedule_executions")
}

model AutomationScheduleLock {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId     String   @unique @map("schedule_id") @db.Uuid
  ownerNodeId    String   @map("owner_node_id")
  leaseExpiresAt DateTime @map("lease_expires_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  schedule       AutomationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("automation_schedule_locks")
}

model AutomationSchedulerNode {
  id          String   @id
  hostname    String
  processId   Int      @map("process_id")
  heartbeatAt DateTime @map("heartbeat_at") @db.Timestamptz
  version     String
  status      String   // ACTIVE, INACTIVE

  @@map("automation_scheduler_nodes")
}

model AutomationRetryQueue {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId       String   @map("workspace_id") @db.Uuid
  provider          String
  providerAccountId String   @map("provider_account_id")
  eventName         String   @map("event_name")
  payload           Json
  correlationId     String   @map("correlation_id") @db.Uuid
  causationId       String   @map("causation_id") @db.Uuid
  actionId          String?  @map("action_id") @db.Uuid
  retryCount        Int      @default(0) @map("retry_count")
  maxRetries        Int      @default(5) @map("max_retries")
  nextRetryAt       DateTime @map("next_retry_at") @db.Timestamptz
  status            String   // PENDING, RUNNING, COMPLETED, FAILED
  priority          String   @default("NORMAL") // HIGH, NORMAL, LOW
  idempotencyKey    String   @unique @map("idempotency_key")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("automation_retry_queue")
}

model AutomationDeadLetter {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId   String   @map("workspace_id") @db.Uuid
  provider      String
  eventName     String   @map("event_name")
  payload       Json
  correlationId String   @map("correlation_id") @db.Uuid
  causationId   String   @map("causation_id") @db.Uuid
  reason        String
  retryCount    Int      @default(0) @map("retry_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("automation_dead_letters")
}

model AutomationCircuitBreaker {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider          String
  providerAccountId String    @map("provider_account_id")
  workspaceId       String    @map("workspace_id") @db.Uuid
  status            String    // CLOSED, OPEN, HALF_OPEN
  failureCount      Int       @default(0) @map("failure_count")
  lastFailureAt     DateTime? @map("last_failure_at") @db.Timestamptz
  nextAttemptAt     DateTime? @map("next_attempt_at") @db.Timestamptz
  recoveryTimeoutMs Int       @default(60000) @map("recovery_timeout_ms")
  failureThreshold  Int       @default(5) @map("failure_threshold")
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([provider, providerAccountId, workspaceId], name: "provider_account_workspace")
  @@map("automation_circuit_breakers")
}

model AutomationFailureHistory {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  provider       String
  classification String   // AUTHORIZATION, VALIDATION, CONFIGURATION, RATE_LIMIT, NETWORK, DATABASE, TIMEOUT, TRANSIENT, UNKNOWN
  severity       String   // LOW, MEDIUM, HIGH, CRITICAL
  error          String
  correlationId  String   @map("correlation_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("automation_failure_history")
}

model AutomationWorkflow {
