datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum WorkspaceType {
  SAFE
  ADVANCED
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum WorkspaceVisibility {
  PRIVATE
  TEAM
  ORGANIZATION
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  APP_PROMOTION
  SALES
}

enum CampaignStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
  FAILED
}

model SystemSetting {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settingKey   String   @unique @map("setting_key")
  settingValue Json     @map("setting_value")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("system_settings")
}

model User {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                    @unique
  name                    String?
  passwordHash            String                    @map("password_hash")
  status              String                        @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  emailVerifiedAt     DateTime?                     @map("email_verified_at") @db.Timestamptz
  createdAt           DateTime                      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?                     @map("deleted_at") @db.Timestamptz
  sessions            UserSession[]
  invitations         UserInvitation[]              @relation("CreatedByRelation")
  organizations       Organization[]                @relation("OwnerRelation")
  workspaceMembers    WorkspaceMember[]
  organizationMembers OrganizationMember[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  userWorkspaceRoles  UserWorkspaceRole[]
  metaConnections     MetaConnection[]
  campaignsCreated    Campaign[]                    @relation("CampaignCreatedBy")
  campaignsUpdated    Campaign[]                    @relation("CampaignUpdatedBy")
  campaignsPublished  Campaign[]                    @relation("CampaignPublishedBy")
  campaignSnapshots   CampaignHistory[]
  adsetsCreated       AdSet[]                       @relation("AdSetCreatedBy")
  adsetsUpdated       AdSet[]                       @relation("AdSetUpdatedBy")
  adsetsPublished     AdSet[]                       @relation("AdSetPublishedBy")
  adsetSnapshots      AdSetHistory[]
  creativesCreated    AdCreative[]                  @relation("CreativeCreatedBy")
  creativesUpdated    AdCreative[]                  @relation("CreativeUpdatedBy")
  creativesPublished  AdCreative[]                  @relation("CreativePublishedBy")
  creativeSnapshots   AdCreativeHistory[]
  adsCreated          Ad[]                          @relation("AdCreatedBy")
  adsUpdated          Ad[]                          @relation("AdUpdatedBy")
  adsPublished        Ad[]                          @relation("AdPublishedBy")
  adSnapshots         AdHistory[]
  mediaAssetsCreated  MediaAsset[]                  @relation("MediaAssetCreatedBy")
  mediaSnapshots      MediaHistory[]
  lifecycleHistories  CampaignLifecycleHistory[]
  adsetLifecycleHistories AdSetLifecycleHistory[]
  creativeLifecycleHistories AdCreativeLifecycleHistory[]
  adLifecycleHistories       AdLifecycleHistory[]

  @@map("users")
}

model UserSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  device         String?
  browser        String?
  os             String?
  country        String?
  city           String?
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model UserInvitation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String
  tenantId    String?   @map("tenant_id") @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  roleId      String?   @map("role_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  status      String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED, CANCELLED
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  creator      User?         @relation("CreatedByRelation", fields: [createdBy], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("user_invitations")
}

model Organization {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  slug                  String                 @unique
  status                String                 @default("ACTIVE") // ACTIVE, ARCHIVED
  ownerUserId           String                 @map("owner_user_id") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?              @map("deleted_at") @db.Timestamptz
  owner                 User                   @relation("OwnerRelation", fields: [ownerUserId], references: [id], onDelete: Restrict)
  invitations           UserInvitation[]
  workspaces            Workspace[]
  members               OrganizationMember[]
  metaConnections       MetaConnection[]
  metaBusinesses        MetaBusiness[]
  metaPages             MetaPage[]
  metaAdAccounts        MetaAdAccount[]
  metaInstagramAccounts MetaInstagramAccount[]
  metaPixels            MetaPixel[]
  metaCatalogs          MetaCatalog[]
  metaSyncHistories     MetaSyncHistory[]
  metaBusinessPages     MetaBusinessPage[]
  metaBusinessAdAccounts MetaBusinessAdAccount[]
  metaBusinessPixels    MetaBusinessPixel[]
  metaBusinessCatalogs  MetaBusinessCatalog[]
  metaPageInstagrams    MetaPageInstagram[]
  metaAdAccountPixels   MetaAdAccountPixel[]
  campaigns             Campaign[]

  @@map("organizations")
}

model Workspace {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  name           String
  slug           String
  description    String?
  workspaceType  WorkspaceType       @map("workspace_type")
  visibility     WorkspaceVisibility @default(ORGANIZATION)
  status         WorkspaceStatus     @default(ACTIVE)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  settings              WorkspaceSettings?
  preferences           WorkspacePreferences?
  members               WorkspaceMember[]
  userWorkspaceRoles    UserWorkspaceRole[]
  metaConnections       MetaConnection[]
  metaBusinesses        MetaBusiness[]
  metaPages             MetaPage[]
  metaAdAccounts        MetaAdAccount[]
  metaInstagramAccounts MetaInstagramAccount[]
  metaPixels            MetaPixel[]
  metaCatalogs          MetaCatalog[]
  metaSyncHistories     MetaSyncHistory[]
  metaBusinessPages     MetaBusinessPage[]
  metaBusinessAdAccounts MetaBusinessAdAccount[]
  metaBusinessPixels    MetaBusinessPixel[]
  metaBusinessCatalogs  MetaBusinessCatalog[]
  metaPageInstagrams    MetaPageInstagram[]
  metaAdAccountPixels   MetaAdAccountPixel[]
  campaigns             Campaign[]
  ads                   Ad[]
  mediaAssets           MediaAsset[]
  mediaFolders          MediaFolder[]
  campaignInsights      CampaignInsight[]
  adsetInsights         AdSetInsight[]
  adInsights            AdInsight[]
  insightSyncHistories  InsightSyncHistory[]
  statusSyncHistories   StatusSyncHistory[]
  automationRules       AutomationRule[]

  @@unique([organizationId, slug], name: "organizationId_slug")
  @@map("workspaces")
}

model WorkspaceSettings {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId        String   @unique @map("workspace_id") @db.Uuid
  timezone           String   @default("UTC")
  language           String   @default("en")
  dateFormat         String   @default("YYYY-MM-DD") @map("date_format")
  timeFormat         String   @default("HH:mm:ss") @map("time_format")
  theme              String   @default("dark")
  defaultLandingPage String   @default("/dashboard") @map("default_landing_page")
  notificationPrefs  Json     @default("{}") @map("notification_prefs")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model WorkspacePreferences {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @unique @map("workspace_id") @db.Uuid
  preferences Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_preferences")
}

model WorkspaceMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId], name: "workspaceId_userId")
  @@map("workspace_members")
}

model OrganizationMember {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  roleId         String?          @map("role_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId], name: "organizationId_userId")
  @@map("organization_members")
}

model VerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  tokenType String    @map("token_type")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String
  roleType    String   @map("role_type")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  permissions         RolePermission[]
  organizationMembers OrganizationMember[]
  userWorkspaceRoles  UserWorkspaceRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actionKey   String   @unique @map("action_key")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserWorkspaceRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, roleId], name: "userId_workspaceId_roleId")
  @@map("user_workspace_roles")
}

model MetaConnection {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facebookUserId       String   @map("facebook_user_id")
  facebookUserName     String   @map("facebook_user_name")
  encryptedAccessToken String   @map("encrypted_access_token")
  expiresAt            DateTime @map("expires_at") @db.Timestamptz
  grantedScopes        Json     @map("granted_scopes")
  provider             String   @default("meta")
  status               String   @default("ACTIVE")
  connectedBy          String   @map("connected_by") @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  workspaceId          String   @map("workspace_id") @db.Uuid
  lastValidatedAt      DateTime @map("last_validated_at") @db.Timestamptz
  connectionVersion    Int      @default(1) @map("connection_version")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user         User         @relation(fields: [connectedBy], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider], name: "workspaceId_provider")
  @@map("meta_connections")
}

model MetaBusiness {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  provider       String         @default("meta")
  externalId     String         @map("external_id")
  name           String
  status         String         @default("ACTIVE")
  rawPayload     Json           @map("raw_payload")
  syncedAt       DateTime       @map("synced_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  campaigns      Campaign[]

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_businesses")
}

model MetaPage {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  provider       String         @default("meta")
  externalId     String         @map("external_id")
  name           String
  status         String         @default("ACTIVE")
  rawPayload     Json           @map("raw_payload")
  syncedAt       DateTime       @map("synced_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  adsets         AdSet[]
  creatives      AdCreative[]

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_pages")
}

model MetaAdAccount {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  provider       String         @default("meta")
  externalId     String         @map("external_id")
  name           String
  status         String         @default("ACTIVE")
  rawPayload     Json           @map("raw_payload")
  syncedAt       DateTime       @map("synced_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  campaigns      Campaign[]

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_ad_accounts")
}

model MetaInstagramAccount {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  provider       String         @default("meta")
  externalId     String         @map("external_id")
  name           String
  status         String         @default("ACTIVE")
  rawPayload     Json           @map("raw_payload")
  syncedAt       DateTime       @map("synced_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  adsets         AdSet[]
  creatives      AdCreative[]

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_instagram_accounts")
}

model MetaPixel {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  provider       String         @default("meta")
  externalId     String         @map("external_id")
  name           String
  status         String         @default("ACTIVE")
  rawPayload     Json           @map("raw_payload")
  syncedAt       DateTime       @map("synced_at") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz
  adsets         AdSet[]
  creatives      AdCreative[]

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_pixels")
}

model MetaCatalog {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  provider       String    @default("meta")
  externalId     String    @map("external_id")
  name           String
  status         String    @default("ACTIVE")
  rawPayload     Json      @map("raw_payload")
  syncedAt       DateTime  @map("synced_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([externalId, provider, workspaceId], name: "externalId_provider_workspaceId")
  @@map("meta_catalogs")
}

model MetaSyncHistory {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  startedAt      DateTime  @map("started_at") @db.Timestamptz
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz
  duration       Int?
  assetCount     Int       @default(0) @map("asset_count")
  status         String    @default("RUNNING") // RUNNING, SUCCESS, FAILED
  error          String?

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("meta_sync_histories")
}

model MetaBusinessPage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  sourceExternalId String    @map("source_external_id")
  targetExternalId String    @map("target_external_id")
  provider         String    @default("meta")
  status           String    @default("ACTIVE")
  syncedAt         DateTime  @map("synced_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sourceExternalId, targetExternalId, provider, workspaceId], name: "source_target_provider_workspace")
  @@map("meta_business_pages")
}

model MetaBusinessAdAccount {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  sourceExternalId String    @map("source_external_id")
  targetExternalId String    @map("target_external_id")
  provider         String    @default("meta")
  status           String    @default("ACTIVE")
  syncedAt         DateTime  @map("synced_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sourceExternalId, targetExternalId, provider, workspaceId], name: "source_target_provider_workspace")
  @@map("meta_business_ad_accounts")
