{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && prisma generate --schema=src/infrastructure/database/prisma/schema.prisma",
    "start": "node --env-file=../../.env dist/main.js",
    "dev": "tsc-watch --onSuccess \"node --env-file=../../.env dist/main.js\"",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema=src/infrastructure/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/infrastructure/database/prisma/schema.prisma",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.1.0",
    "@prisma/client": "^5.10.0",
    "argon2": "^0.40.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "rxjs": "^7.8.1",
    "shared-types": "workspace:*",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.1",
    "ai-copilot": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "eslint-config-custom": "workspace:*",
    "prisma": "^5.10.0",
    "tsc-watch": "^6.0.0",
    "tsconfig": "workspace:*",
    "typescript": "^5.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "@types/jest": "^29.5.12"
  }
}
