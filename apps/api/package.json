{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && prisma generate --schema=src/infrastructure/database/prisma/schema.prisma",
    "start": "node --env-file=../../.env dist/main.js",
    "dev": "tsc-watch --onSuccess \"node --env-file=../../.env dist/main.js\"",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate --schema=src/infrastructure/database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/infrastructure/database/prisma/schema.prisma",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/client": "^7.9.0",
    "argon2": "^0.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "rxjs": "^7.8.1",
    "shared-types": "workspace:*",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "bullmq": "^5.80.10",
    "ioredis": "^5.4.1",
    "ai-copilot": "workspace:*",
    "notifications-engine": "workspace:*",
    "plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "eslint-config-custom": "workspace:*",
    "prisma": "^7.9.0",
    "tsc-watch": "^7.2.1",
    "tsconfig": "workspace:*",
    "typescript": "^7.0.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.12",
    "@types/jest": "^30.0.0"
  }
}
